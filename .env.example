# ================================================
# JagaDiri — Environment Variables
# ================================================
# Salin file ini menjadi .env dan sesuaikan nilainya
# cp .env.example .env

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://jagadiri_user:jagadiri_secret_2024@localhost:5432/jagadiri
REDIS_URL=redis://localhost:6379/0

# === AUTH ===
JWT_SECRET_KEY=jagadiri-dev-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === THIRD PARTY (isi untuk produksi) ===
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FIREBASE_SERVICE_ACCOUNT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
GOOGLE_MAPS_API_KEY=

# === STORAGE ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_MEDICAL_FILES=jagadiri-medical
MINIO_BUCKET_PROFILE_PHOTOS=jagadiri-profiles

# === APP ===
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ADMIN_EMAIL=admin@jagadiri.id
SUPPORT_EMAIL=support@jagadiri.id

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
