# ================================================
# JagaDiri — Backend API Environment Variables
# ================================================
# Salin file ini menjadi .env:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/Mac)
#
# Letakkan file .env ini di folder: services/api/
# JANGAN commit .env ke Git!
# ================================================

# ─────────────────────────────────────────────────
# DATABASE — Supabase Session Pooler (WAJIB DIISI)
# ─────────────────────────────────────────────────
# 1. Buka Supabase Dashboard → Project → Settings → Database
# 2. Pilih tab "Connection string"
# 3. Pilih mode: "Session pooler" (port 5432)
# 4. Salin connection string dan ganti [YOUR-PASSWORD] dengan password project Anda
# 5. Ubah prefix dari "postgresql://" menjadi "postgresql+asyncpg://"
#    dan tambahkan "?ssl=require" di akhir
#
# Format akhir:
#   postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres?ssl=require
#
# ⚠️  PERINGATAN KEAMANAN:
#   Jika password Anda pernah terekspos (terlihat di git history, frontend, dll),
#   SEGERA ganti password di: Supabase Dashboard → Settings → Database → Reset database password
#
DATABASE_URL="postgresql+asyncpg://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?ssl=require"

# ─────────────────────────────────────────────────
# AUTH / JWT
# ─────────────────────────────────────────────────
# Ganti dengan random string yang kuat (min 32 karakter) untuk produksi
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=jagadiri-dev-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Enkripsi data medis — ganti di produksi (harus tepat 32 karakter)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ADMIN_EMAIL=admin@jagadiri.id
SUPPORT_EMAIL=support@jagadiri.id

# ─────────────────────────────────────────────────
# REDIS (opsional)
# ─────────────────────────────────────────────────
# Kosongkan jika tidak menggunakan Redis (fallback in-memory tersedia).
# Untuk Redis lokal: redis://localhost:6379/0
REDIS_URL=

# ─────────────────────────────────────────────────
# THIRD PARTY (isi untuk produksi)
# ─────────────────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────
# STORAGE (MinIO, opsional untuk MVP)
# ─────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_MEDICAL_FILES=jagadiri-medical
MINIO_BUCKET_PROFILE_PHOTOS=jagadiri-profiles
